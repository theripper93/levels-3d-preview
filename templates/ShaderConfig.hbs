<div class="flexcol" autocomplete="off">
    <nav class="sheet-tabs tabs" data-group="sections">
        {{#each shaders}}
            <a class="item {{#if this.isEnabled}}shader-tab-enabled{{/if}}" data-tab="{{@key}}">{{{this.icon}}} {{this.title}}</a>
        {{/each}}
    </nav>


    <section id="config-tabs" class="content scrollable" style="max-height: 50vh;">
        {{#each shaders}}
            <div class="tab" data-tab="{{@key}}" data-group="sections">
                <p class="hint">{{#if this.isSlow}}<i id="levels-3d-preview-slow-shader" data-tooltip="{{localize "levels3dpreview.shaders.config.slow"}}" class="fas fa-exclamation-triangle"></i> {{/if}}{{this.description}}</p>
                {{#each this}}
                    {{#if this.isField}}
                        <div class="form-group" data-tooltip-direction="RIGHT" {{#if this.isTexture}}{{#if this.value}}data-tooltip="<img width=200 height=200 src='{{this.value}}'>"{{/if}}{{/if}}>
                            <label>{{this.title}}</label>
                            <div class="form-fields">
                                {{#if this.isNumber}}
                                    <input type="number" name="{{@../key}}.{{@key}}" step="any" data-dtype="Number" value="{{this.value}}"/>
                                {{/if}}
                                {{#if this.isSlider}}
                                    {{rangePicker name=(concat @../key "." @key) value=this.value min=this.min max=this.max step=this.step}}
                                {{/if}}
                                {{#if this.isBoolean}}
                                    <input type="checkbox" name="{{@../key}}.{{@key}}" data-dtype="Boolean" {{checked this.value}}/>
                                {{/if}}
                                {{#if this.isTexture}}
                                <file-picker name="{{@../key}}.{{@key}}" type="image" value="{{this.value}}">
                                </file-picker>
                                {{/if}}
                                {{#if this.isColor}}
                                    {{colorPicker name=(concat @../key "." @key) value=this.value}}
                                {{/if}}
                            </div>
                        </div>
                    {{/if}}
                {{/each}}
            </div>
        {{/each}}

    </section>


    <footer class="form-footer flexrow">
        <button type="submit" name="submit">
            <i class="fas fa-save"></i> {{localize "levels3dpreview.shaders.config.save"}}
        </button>
        <button id="apply">
            <i class="fas fa-check"></i> {{localize "levels3dpreview.shaders.config.apply"}}
        </button>
        <button id="tomacro">
            <i class="fas fa-code"></i></i> {{localize "levels3dpreview.shaders.config.macro-btn"}}
        </button>
    </footer>
</form>