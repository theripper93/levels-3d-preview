<section class='tab {{tab.cssClass}}' data-group='primary' data-tab='misc'>

    <div class="form-group">
        <label>{{localize "levels3dpreview.settings.miniCanvas.name"}}</label>
        <input type="checkbox" name="miniCanvas" data-dtype="Boolean" {{checked miniCanvas}} />
        <p class="hint">{{localize "levels3dpreview.settings.miniCanvas.hint"}}</p>
    </div>

    <div class="form-group">
        <label>{{localize "levels3dpreview.settings.pingsound.name"}}</label>
        <div class="form-fields">
            <file-picker accept="audio" type="audio" name="pingsound" value="{{pingsound}}" data-dtype="String" />
        </div>
        <p class="hint">{{localize "levels3dpreview.settings.pingsound.hint"}}</p>
    </div>

    <div class="form-group">
        <label>{{localize "levels3dpreview.settings.navigatorAuto.name"}}</label>
        <select name="navigatorAuto" data-dtype="String">
            <option {{#if (eq navigatorAuto "none")}}selected{{/if}} value="none">{{localize "levels3dpreview.settings.navigatorAuto.options.none"}}</option>
            <option {{#if (eq navigatorAuto "players")}}selected{{/if}} value="players">{{localize "levels3dpreview.settings.navigatorAuto.options.players"}}</option>
            <option {{#if (eq navigatorAuto "all")}}selected{{/if}} value="all">{{localize "levels3dpreview.settings.navigatorAuto.options.all"}}</option>
        </select>
        <p class="hint">{{localize "levels3dpreview.settings.navigatorAuto.hint"}}</p>
    </div>

    <div class="form-group">
        <label>{{localize "levels3dpreview.settings.showAdvanced.name"}}</label>
        <input type="checkbox" name="showAdvanced" data-dtype="Boolean" {{checked showAdvanced}} />
        <p class="hint">{{localize "levels3dpreview.settings.showAdvanced.hint"}}</p>
    </div>

    <div class="form-group">
        <label>{{localize "levels3dpreview.settings.cameralockzero.name"}}</label>
        <input type="checkbox" name="cameralockzero" data-dtype="Boolean" {{checked cameralockzero}} />
        <p class="hint">{{localize "levels3dpreview.settings.cameralockzero.hint"}}</p>
    </div>

    <div class="form-group">
        <label>{{localize "levels3dpreview.settings.sharedContext.name"}}</label>
        <input type="checkbox" name="sharedContext" data-dtype="Boolean" {{checked sharedContext}} />
        <p class="hint">{{localize "levels3dpreview.settings.sharedContext.hint"}}</p>
    </div>      

    <div class="form-group">
        <label>{{localize "levels3dpreview.settings.lightCacheSize.name"}}</label>
        <input type="number" name="lightCacheSize" data-dtype="Number" value="{{lightCacheSize}}" />
        <p class="hint">{{localize "levels3dpreview.settings.lightCacheSize.hint"}}</p>
    </div>

    <div class="form-group">
        <label>{{localize "levels3dpreview.settings.debugMode.name"}}</label>
        <input type="checkbox" name="debugMode" data-dtype="Boolean" {{checked debugMode}} />
        <p class="hint">{{localize "levels3dpreview.settings.debugMode.hint"}}</p>
    </div>

</section>