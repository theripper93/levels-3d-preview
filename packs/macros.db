{"name":"Change All Doors Texture","type":"script","author":"Cspu3pxFr7tu7SU7","img":"icons/svg/door-closed-outline.svg","scope":"global","command":"const texturePath = \"\";\nif(!texturePath) return;\ncanvas.walls.updateAll( {\"flags.levels-3d-preview.wallTexture\" : texturePath} , (w)=> w.isDoor)","folder":null,"sort":0,"permission":{"default":0,"Cspu3pxFr7tu7SU7":3},"flags":{"socketmacros":{"isSocket":false},"advanced-macros":{"runAsGM":false},"core":{"sourceId":"Macro.vtIaG2xXYD36M36m"},"scene-packer":{"sourceId":"Macro.vtIaG2xXYD36M36m","hash":"481490f35c5c77185a87143edbc36a67fb2f49ce"}},"_id":"ph0Q4ggmHLhGJPaD"}
{"name":"Fit Tile To Scene","type":"script","author":"Cspu3pxFr7tu7SU7","img":"icons/svg/mountain.svg","scope":"global","command":"canvas.activeLayer.controlled[0].document.update({\nx: canvas.dimensions.paddingX,\ny: canvas.dimensions.paddingY,\nwidth: canvas.dimensions.sceneWidth,\nheight: canvas.dimensions.sceneHeight,\n})","folder":null,"sort":0,"permission":{"default":0,"yjDURLhSy6ZUAhtN":3,"Cspu3pxFr7tu7SU7":3},"flags":{"combat-utility-belt":{"macroTrigger":""},"furnace":{"runAsGM":false},"core":{"sourceId":"Macro.u6QVVpCXkQ8ez7jm"}},"_id":"qtDU1XWQAYsuuYce"}
{"name":"Center Token","type":"script","author":"Cspu3pxFr7tu7SU7","img":"icons/svg/circle.svg","scope":"global","command":"const tk = canvas.tokens.controlled[0]\n\ntk.document.update({\n    x: canvas.scene.dimensions.width/2-tk.w/2,\n    y: canvas.scene.dimensions.height/2-tk.h/2,\n    rotation: 0,\n},{animate:false});","folder":null,"sort":0,"permission":{"default":0,"Cspu3pxFr7tu7SU7":3},"flags":{"advanced-macros":{"runAsGM":false},"socketmacros":{"isSocket":false},"core":{"sourceId":"Macro.njUUW9tKL5qYrFGm"}},"_id":"uEEUyMPpr4Ra8xRA"}
{"name":"Randomize","type":"script","author":"Cspu3pxFr7tu7SU7","img":"icons/svg/d20-grey.svg","scope":"global","command":"const updates = canvas.background.placeables.map((t) => {return {_id: t.id,flags: {\"levels-3d-preview\": {\"randomSeed\": randomID(7)}}}}).concat(canvas.foreground.placeables.map((t) => {return {_id: t.id,flags: {\"levels-3d-preview\": {\"randomSeed\": randomID(7)}}}}))\n\ncanvas.scene.updateEmbeddedDocuments(\"Tile\", updates)","folder":null,"sort":0,"permission":{"default":0,"Cspu3pxFr7tu7SU7":3},"flags":{"socketmacros":{"isSocket":true},"core":{"sourceId":"Macro.pywnVltrcPRfzw25"}},"_id":"VslzTgcQNKV8havv"}
