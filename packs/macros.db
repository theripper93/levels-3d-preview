{"name":"Randomize all Seeds","type":"script","author":"Cspu3pxFr7tu7SU7","img":"icons/svg/d20-grey.svg","scope":"global","command":"const updates = canvas.background.placeables.map((t) => {return {_id: t.id,flags: {\"levels-3d-preview\": {\"randomSeed\": randomID(7)}}}}).concat(canvas.foreground.placeables.map((t) => {return {_id: t.id,flags: {\"levels-3d-preview\": {\"randomSeed\": randomID(7)}}}}))\n\ncanvas.scene.updateEmbeddedDocuments(\"Tile\", updates)","folder":null,"sort":0,"permission":{"default":0,"Cspu3pxFr7tu7SU7":3},"flags":{"socketmacros":{"isSocket":true},"core":{"sourceId":"Macro.pywnVltrcPRfzw25"}},"_id":"rQ5qVGzSMX2WY8XF"}
