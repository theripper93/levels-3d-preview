                "name": "Colorize Highlight Image",
                "hint": "Colorize the Highlight Image to match default foundry border colors."
            },
            "hideTarget": {
                "name": "Hide Target Indicator (if solid base)",
                "hint": "Hide the target indicator if the token has the base enabled, the targets will be shown in the base ring highlight."
            },
